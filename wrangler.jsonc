{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "plotlist",
  "main": "worker/index.ts",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/files/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "plotlist",
      "database_id": "8864a293-ae24-4153-9d76-71c228d40207",
      "migrations_dir": "drizzle"
    }
  ],
  "r2_buckets": [
    {
      "binding": "UPLOADS",
      "bucket_name": "plotlist-uploads"
    }
  ],
  "triggers": {
    "crons": ["*/20 * * * *", "40 * * * *", "10 * * * *", "5 */6 * * *"]
  },
  "vars": {
    "NODE_ENV": "production",
    "GEMINI_EMBEDDING_MODEL": "gemini-embedding-2-preview",
    "GEMINI_EMBEDDING_VERSION": "shows-v1"
  },
  "observability": {
    "enabled": true
  }
}
