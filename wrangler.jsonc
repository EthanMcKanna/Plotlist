{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "plotlist",
  "main": "worker/index.ts",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "routes": [
    { "pattern": "plotlist.app", "custom_domain": true },
    { "pattern": "www.plotlist.app", "custom_domain": true }
  ],
  // Keep workers.dev alive until all shipped app builds point at plotlist.app.
  "workers_dev": true,
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/files/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "plotlist",
      "database_id": "8864a293-ae24-4153-9d76-71c228d40207",
      "migrations_dir": "drizzle"
    }
  ],
  "r2_buckets": [
    {
      "binding": "UPLOADS",
      "bucket_name": "plotlist-uploads"
    }
  ],
  "vectorize": [
    {
      "binding": "VECTORIZE",
      "index_name": "plotlist-shows-v2"
    }
  ],
  "triggers": {
    "crons": ["* * * * *", "*/20 * * * *", "40 * * * *", "10 * * * *", "5 */6 * * *", "2-57/5 * * * *"]
  },
  "vars": {
    "NODE_ENV": "production",
    "GEMINI_EMBEDDING_MODEL": "gemini-embedding-2",
    "GEMINI_EMBEDDING_VERSION": "shows-v2-ge2-1536",
    "SENTRY_DSN": "https://60e85cc7b00be6a37f0d56afae9b2827@o4511680500334592.ingest.us.sentry.io/4511680705462272"
  },
  "observability": {
    "enabled": true
  }
}
