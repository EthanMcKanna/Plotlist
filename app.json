{
  "expo": {
    "name": "Plotlist",
    "slug": "Showboxd",
    "scheme": "showboxd",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSContactsUsageDescription": "Allow Plotlist to access your contacts so you can find friends already using the app.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.emckanna.Plotlist"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.RECORD_AUDIO",
        "android.permission.WRITE_CONTACTS"
      ],
      "package": "com.emckanna.Plotlist"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Plotlist to access your photos to upload an avatar.",
          "cameraPermission": "Allow Plotlist to access your camera to upload an avatar."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow Plotlist to access your contacts so you can find friends already using the app."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e009a9cf-083e-4943-9b1c-67cdcdadc58f"
      }
    }
  }
}
