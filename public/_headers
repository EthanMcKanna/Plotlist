# Cloudflare Workers static assets honor this file (Pages-style syntax).
# Everything under /_expo/static is content-hashed by the export, so it can
# cache forever; index.html keeps the platform's must-revalidate default.
/_expo/static/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.ico
  Cache-Control: public, max-age=86400

/apple-touch-icon.png
  Cache-Control: public, max-age=86400

/icon-192.png
  Cache-Control: public, max-age=86400

/icon-512.png
  Cache-Control: public, max-age=86400

/og-image.png
  Cache-Control: public, max-age=86400

/manifest.webmanifest
  Cache-Control: public, max-age=3600
